# Server
PORT=4000

# Allowed browser origins (comma-separated). Use * to allow all.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app (or comma-separated list)
# .vercel.app subdomains are also allowed automatically.
CLIENT_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/collab-editor

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
