# Local development (default when unset)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000/collab

# Production (set these in Vercel → Project → Settings → Environment Variables)
# NEXT_PUBLIC_API_URL=https://assignment-house-of-edtech.onrender.com/api
# NEXT_PUBLIC_WS_URL=wss://assignment-house-of-edtech.onrender.com/collab
#
# If NEXT_PUBLIC_WS_URL is omitted, it is derived from NEXT_PUBLIC_API_URL
# (https → wss, http → ws). On HTTPS pages, ws:// is auto-upgraded to wss://.
